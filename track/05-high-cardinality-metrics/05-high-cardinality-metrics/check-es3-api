#!/usr/bin/env bash
# Challenge 5 check: verify Streams exist with correct retention and processing rules,
# and that both backing indices have data.
set -euo pipefail

fail() { echo "❌ $*"; exit 1; }
pass() { echo "✅ $*"; }
info() { echo "ℹ️  $*"; }

ES_URL=$(agent variable get ES_URL 2>/dev/null || echo "")
ES_API_KEY=$(agent variable get ES_API_KEY 2>/dev/null || echo "")
ES_USERNAME=$(agent variable get ES_USERNAME 2>/dev/null || echo "admin")
ES_PASSWORD=$(agent variable get ES_PASSWORD 2>/dev/null || echo "")
KIBANA_URL=$(agent variable get ES_KIBANA_URL 2>/dev/null || echo "")

[[ -z "$ES_URL" ]] && fail "ES_URL not set."
if [[ -n "$ES_API_KEY" ]]; then
  AUTH="Authorization: ApiKey ${ES_API_KEY}"
  KB_AUTH="Authorization: ApiKey ${ES_API_KEY}"
else
  AUTH="Authorization: Basic $(echo -n "${ES_USERNAME}:${ES_PASSWORD}" | base64)"
  KB_AUTH="Authorization: Basic $(echo -n "${ES_USERNAME}:${ES_PASSWORD}" | base64)"
fi

# ── Data in detailed stream ───────────────────────────────────────────────────
DETAILED_COUNT=$(curl -sk "${ES_URL}/lab5-k8s-detailed-*/_count" \
  -H "$AUTH" | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))")
[[ "$DETAILED_COUNT" -ge 100 ]] || fail "Expected ≥100 docs in lab5-k8s-detailed, got ${DETAILED_COUNT}."
pass "Detailed stream documents: ${DETAILED_COUNT}"

# ── Data in summary stream ────────────────────────────────────────────────────
SUMMARY_COUNT=$(curl -sk "${ES_URL}/lab5-k8s-summary-*/_count" \
  -H "$AUTH" | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))")
[[ "$SUMMARY_COUNT" -ge 100 ]] || fail "Expected ≥100 docs in lab5-k8s-summary, got ${SUMMARY_COUNT}."
pass "Summary stream documents: ${SUMMARY_COUNT}"

# ── Summary stream should NOT have pod.uid field ──────────────────────────────
HAS_POD_UID=$(curl -sk -X POST "${ES_URL}/lab5-k8s-summary-*/_search" \
  -H "$AUTH" -H "Content-Type: application/json" \
  -d '{"size":0,"aggs":{"has_uid":{"filter":{"exists":{"field":"kubernetes.pod.uid"}}}}}' \
  | python3 -c "import sys,json; print(json.load(sys.stdin)['aggregations']['has_uid']['doc_count'])")
if [[ "$HAS_POD_UID" -eq 0 ]]; then
  pass "Summary stream correctly has no kubernetes.pod.uid field (processing rule working)"
else
  info "Summary stream still contains pod.uid in ${HAS_POD_UID} docs (Stream processing rule may apply only to new ingest)"
fi

# ── Kibana Streams API check (best-effort) ────────────────────────────────────
if [[ -n "$KIBANA_URL" ]]; then
  STREAM_LIST=$(curl -sk "${KIBANA_URL}/api/streams" \
    -H "$KB_AUTH" | python3 -c "
import sys, json
try:
    streams = json.load(sys.stdin).get('streams', [])
    names = [s.get('name','') for s in streams if 'lab5' in s.get('name','')]
    print(','.join(names))
except: print('')
" 2>/dev/null || echo "")

  if echo "$STREAM_LIST" | grep -q "lab5-k8s-detailed"; then
    pass "Stream lab5-k8s-detailed exists in Kibana Streams"
  else
    info "Stream lab5-k8s-detailed not yet visible via Streams API (may take a moment)"
  fi

  if echo "$STREAM_LIST" | grep -q "lab5-k8s-summary"; then
    pass "Stream lab5-k8s-summary exists in Kibana Streams"
  else
    info "Stream lab5-k8s-summary not yet visible via Streams API (may take a moment)"
  fi
fi

echo ""
echo "🎉 Lab 5 complete! Two streams, two retention policies, one ingest pipeline."
echo "   Splunk requires agent-level changes to control cardinality — and you lose the data globally."
echo "   Elastic Streams lets you keep it in one stream and summarise it in another."
exit 0
