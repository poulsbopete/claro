#!/usr/bin/env bash
# Challenge 7 solve: auto-complete for facilitators / testing.
set -euo pipefail
log() { printf "[ch7-solve] %s\n" "$*"; }

ES_URL=$(agent variable get ES_URL 2>/dev/null || echo "")
ES_API_KEY=$(agent variable get ES_API_KEY 2>/dev/null || echo "")
ES_USERNAME=$(agent variable get ES_USERNAME 2>/dev/null || echo "admin")
ES_PASSWORD=$(agent variable get ES_PASSWORD 2>/dev/null || echo "")
ATTACK_IP=$(agent variable get LAB7_ATTACK_IP 2>/dev/null || echo "198.51.100.42")

if [[ -n "$ES_API_KEY" ]]; then AUTH="Authorization: ApiKey ${ES_API_KEY}"
else AUTH="Authorization: Basic $(echo -n "${ES_USERNAME}:${ES_PASSWORD}" | base64)"; fi

COUNT=$(curl -sk "${ES_URL}/lab4-app-logs-*/_count?q=source.ip:${ATTACK_IP}" \
  -H "$AUTH" | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null || echo "0")

log "Attack events found for ${ATTACK_IP}: ${COUNT}"
log "Solve complete."
