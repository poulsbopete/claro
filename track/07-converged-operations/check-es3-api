#!/usr/bin/env bash
# Challenge 7 check: verify brute-force events exist in the observability index
# and (optionally) that the detection rule was created in Kibana Security.
set -euo pipefail

fail() { echo "❌ $*"; exit 1; }
pass() { echo "✅ $*"; }
info() { echo "ℹ️  $*"; }

ES_URL=$(agent variable get ES_URL 2>/dev/null || echo "")
ES_API_KEY=$(agent variable get ES_API_KEY 2>/dev/null || echo "")
ES_USERNAME=$(agent variable get ES_USERNAME 2>/dev/null || echo "admin")
ES_PASSWORD=$(agent variable get ES_PASSWORD 2>/dev/null || echo "")
KIBANA_URL=$(agent variable get ES_KIBANA_URL 2>/dev/null || echo "")
ATTACK_IP=$(agent variable get LAB7_ATTACK_IP 2>/dev/null || echo "198.51.100.42")
LOG_INDEX=$(agent variable get LAB7_LOG_INDEX 2>/dev/null || echo "lab4-app-logs-*")

[[ -z "$ES_URL" ]] && fail "ES_URL not set."
if [[ -n "$ES_API_KEY" ]]; then
  AUTH="Authorization: ApiKey ${ES_API_KEY}"
  KB_AUTH="Authorization: ApiKey ${ES_API_KEY}"
else
  AUTH="Authorization: Basic $(echo -n "${ES_USERNAME}:${ES_PASSWORD}" | base64)"
  KB_AUTH="Authorization: Basic $(echo -n "${ES_USERNAME}:${ES_PASSWORD}" | base64)"
fi

# ── Attack events in the observability index ──────────────────────────────────
ATTACK_COUNT=$(curl -sk "${ES_URL}/${LOG_INDEX}/_count?q=source.ip:${ATTACK_IP}" \
  -H "$AUTH" | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))")

[[ "$ATTACK_COUNT" -ge 10 ]] || fail "Expected ≥10 brute-force events from ${ATTACK_IP} in ${LOG_INDEX}, got ${ATTACK_COUNT}."
pass "Brute-force events found: ${ATTACK_COUNT} events from ${ATTACK_IP} in observability index ${LOG_INDEX}"

# ── Confirm it is the observability index (not a separate SIEM index) ─────────
LOG_DOC_COUNT=$(curl -sk "${ES_URL}/${LOG_INDEX}/_count" \
  -H "$AUTH" | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))")
pass "Observability index ${LOG_INDEX} has ${LOG_DOC_COUNT} total documents (APM logs + security events — same index, zero double-ingest)"

# ── Detection rule check (best-effort) ───────────────────────────────────────
RULE_ID=$(agent variable get LAB7_RULE_ID 2>/dev/null || echo "")
if [[ -n "$RULE_ID" && -n "$KIBANA_URL" ]]; then
  RULE_STATUS=$(curl -sk "${KIBANA_URL}/api/detection_engine/rules?rule_id=lab7-brute-force-observability-001" \
    -H "$KB_AUTH" | python3 -c "import sys,json; r=json.load(sys.stdin); print(r.get('enabled','unknown'))" 2>/dev/null || echo "unknown")
  if [[ "$RULE_STATUS" == "True" || "$RULE_STATUS" == "true" ]]; then
    pass "Detection rule is enabled in Kibana Security (targeting ${LOG_INDEX})"
  else
    info "Detection rule status: ${RULE_STATUS} (may require manual creation or Kibana Security tier)"
  fi
fi

echo ""
echo "🎉 Lab 7 complete! Security detection running on your existing observability logs."
echo "   Splunk requires Splunk ES + CIM + double ingest for equivalent coverage."
echo "   Elastic requires: zero additional infrastructure."
exit 0
