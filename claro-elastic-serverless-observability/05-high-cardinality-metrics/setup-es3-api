#!/usr/bin/env bash
# Challenge 5 setup: Elastic Streams — demonstrate retention and processing rules
# using the real logs.otel stream already flowing from the Claro generators.
set -euo pipefail

log()  { printf "[ch5-setup] %s\n" "$*"; }
warn() { printf "[ch5-setup] WARN: %s\n" "$*"; }

KIBANA_URL=$(agent variable get ES_KIBANA_URL 2>/dev/null || echo "")
ES_API_KEY=$(agent variable get ES_API_KEY 2>/dev/null || echo "")
ES_USERNAME=$(agent variable get ES_USERNAME 2>/dev/null || echo "admin")
ES_PASSWORD=$(agent variable get ES_PASSWORD 2>/dev/null || echo "")

[[ -z "$KIBANA_URL" ]] && { warn "KIBANA_URL not set — skipping Streams API setup."; exit 0; }

if [[ -n "$ES_API_KEY" ]]; then
  KB_AUTH="Authorization: ApiKey ${ES_API_KEY}"
else
  KB_AUTH="Authorization: Basic $(echo -n "${ES_USERNAME}:${ES_PASSWORD}" | base64)"
fi

kb() {
  local method="$1" path="$2" body="${3:-}"
  if [[ -n "$body" ]]; then
    curl -sk -X "$method" "${KIBANA_URL}${path}" \
      -H "$KB_AUTH" -H "Content-Type: application/json" -H "kbn-xsrf: true" -d "$body"
  else
    curl -sk -X "$method" "${KIBANA_URL}${path}" \
      -H "$KB_AUTH" -H "kbn-xsrf: true"
  fi
}

# Ensure Streams is enabled (already done in track setup, but idempotent)
log "Ensuring Elastic Streams is enabled..."
kb POST "/api/streams/_enable" '{}' > /dev/null 2>&1 || true

# Add a processing rule to logs.otel: drop kubernetes.pod.uid from long-lived stream
# This demonstrates the core Splunk-vs-Elastic narrative:
# Elastic: drop high-cardinality fields at the stream level, not the agent level
log "Adding drop_field processing rule for kubernetes.pod.uid on logs.otel..."
RULE_RESP=$(kb PUT "/api/streams/logs.otel" "$(cat <<'EOF'
{
  "ingest": {
    "lifecycle": { "dsl": { "data_retention": "7d" } },
    "processing": [
      {
        "condition": { "field": "kubernetes.pod.uid", "operator": "exists" },
        "processors": [
          { "name": "drop_field", "field": "kubernetes.pod.uid" }
        ]
      }
    ],
    "routing": []
  }
}
EOF
)" 2>/dev/null || echo '{}')

if echo "$RULE_RESP" | python3 -c "import sys,json; r=json.load(sys.stdin); exit(0 if r.get('acknowledged') or r.get('name') else 1)" 2>/dev/null; then
  log "  Processing rule added to logs.otel ✓"
else
  log "  Note: logs.otel update returned: $(echo "$RULE_RESP" | head -c 200)"
  log "  Learner will add the processing rule manually via the Streams UI."
fi

# List current streams for reference
log ""
log "Current streams in project:"
kb GET "/api/streams" 2>/dev/null \
  | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    streams = data.get('streams', data if isinstance(data, list) else [])
    for s in streams[:10]:
        name = s.get('name', '?')
        print(f'  {name}')
except Exception as e:
    print(f'  (could not parse: {e})')
" 2>/dev/null || true

log ""
log "Lab 5 setup complete."
log "Learner will explore the logs.otel stream in the Kibana Streams UI."
exit 0
