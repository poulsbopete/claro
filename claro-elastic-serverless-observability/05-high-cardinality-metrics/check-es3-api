#!/usr/bin/env bash
# Challenge 5 check: verify logs.otel has data and at least one child stream was created.
set -euo pipefail

fail() { echo "❌ $*"; exit 1; }
pass() { echo "✅ $*"; }
info() { echo "ℹ️  $*"; }

ES_URL=$(agent variable get ES_URL 2>/dev/null || echo "")
ES_API_KEY=$(agent variable get ES_API_KEY 2>/dev/null || echo "")
ES_USERNAME=$(agent variable get ES_USERNAME 2>/dev/null || echo "admin")
ES_PASSWORD=$(agent variable get ES_PASSWORD 2>/dev/null || echo "")
KIBANA_URL=$(agent variable get ES_KIBANA_URL 2>/dev/null || echo "")

[[ -z "$ES_URL" ]] && fail "ES_URL not set."

if [[ -n "$ES_API_KEY" ]]; then
  AUTH="Authorization: ApiKey ${ES_API_KEY}"
  KB_AUTH="Authorization: ApiKey ${ES_API_KEY}"
else
  AUTH="Authorization: Basic $(echo -n "${ES_USERNAME}:${ES_PASSWORD}" | base64)"
  KB_AUTH="Authorization: Basic $(echo -n "${ES_USERNAME}:${ES_PASSWORD}" | base64)"
fi

# ── logs.otel has real data ───────────────────────────────────────────────────
LOG_COUNT=$(curl -sk "${ES_URL}/logs.otel/_count" \
  -H "$AUTH" 2>/dev/null \
  | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null || echo "0")

[[ "$LOG_COUNT" -ge 50 ]] || fail "Expected ≥50 documents in logs.otel, got ${LOG_COUNT}. Generators may still be starting — wait 1-2 minutes and retry."
pass "logs.otel has ${LOG_COUNT} documents"

# ── Check for child streams (logs.otel.*) created via partitioning ────────────
if [[ -n "$KIBANA_URL" ]]; then
  CHILD_STREAMS=$(curl -sk "${KIBANA_URL}/api/streams" \
    -H "$KB_AUTH" -H "kbn-xsrf: true" 2>/dev/null \
    | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    streams = data.get('streams', data if isinstance(data, list) else [])
    children = [s.get('name', s.get('id', '')) for s in streams
                if str(s.get('name', s.get('id', ''))).startswith('logs.otel.')]
    print('\n'.join(children))
except Exception as e:
    print('')
" 2>/dev/null || echo "")

  if [[ -n "$CHILD_STREAMS" ]]; then
    COUNT=$(echo "$CHILD_STREAMS" | grep -c "logs.otel\." || true)
    pass "Found ${COUNT} child stream(s) created from partitioning:"
    echo "$CHILD_STREAMS" | while read -r s; do [[ -n "$s" ]] && echo "    → $s"; done
  else
    fail "No child streams found under logs.otel.* — accept at least two partitioning suggestions in the Streams UI, then click Check again."
  fi
else
  info "KIBANA_URL not set — skipping child stream check (non-blocking)"
fi

echo ""
echo "🎉 Lab 5 complete! Elastic Streams auto-detected your service topology and"
echo "   partitioned your log stream with zero agent changes."
echo ""
echo "   In Splunk: modify otelcol-contrib.yaml → deploy to all nodes → restart → verify."
echo "   In Elastic: click Accept. Done."
exit 0
