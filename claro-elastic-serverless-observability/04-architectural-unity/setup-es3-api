#!/usr/bin/env bash
# Challenge 4 setup: Architectural Unity
# Real Claro OTel data is already flowing from the generators started in Lab 1.
# Nothing to inject — just confirm the scenario is still running.
set -euo pipefail

log() { printf "[ch4-setup] %s\n" "$*"; }

DEMO_PORT="${DEMO_PORT:-8090}"

log "Lab 4 — Architectural Unity"
log "Claro scenario generators are already running from Lab 1 setup."
log "Real OTel logs with trace.id correlation are flowing into logs.otel."
log ""

# Verify demo app is still up
if curl -sf "http://localhost:${DEMO_PORT}/health" >/dev/null 2>&1; then
  log "Demo app healthy ✓"
else
  log "WARN: Demo app may not be running — learner can proceed with existing data."
fi

# Check deployment is active
RUNNING=$(curl -sf "http://localhost:${DEMO_PORT}/api/deployments" 2>/dev/null \
  | python3 -c "import sys,json; deps=json.load(sys.stdin); print(sum(1 for d in deps if d.get('running')))" 2>/dev/null || echo "0")

if [[ "$RUNNING" -ge 1 ]]; then
  log "Claro scenario running (${RUNNING} active deployment) ✓"
else
  log "WARN: No active deployments detected. Existing data in logs.otel will still be queryable."
fi

log ""
log "Setup complete. Learner should explore real Claro data in the Elastic Serverless tab."
exit 0
