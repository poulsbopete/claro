#!/usr/bin/env bash
# Challenge 4 check: verify real Claro OTel logs and traces are flowing.
set -euo pipefail

fail() { echo "❌ $*"; exit 1; }
pass() { echo "✅ $*"; }

ES_URL=$(agent variable get ES_URL 2>/dev/null || echo "")
ES_API_KEY=$(agent variable get ES_API_KEY 2>/dev/null || echo "")
ES_USERNAME=$(agent variable get ES_USERNAME 2>/dev/null || echo "admin")
ES_PASSWORD=$(agent variable get ES_PASSWORD 2>/dev/null || echo "")

[[ -z "$ES_URL" ]] && fail "ES_URL not set — track setup may not have completed."

if [[ -n "$ES_API_KEY" ]]; then
  AUTH_HEADER="Authorization: ApiKey ${ES_API_KEY}"
else
  AUTH_HEADER="Authorization: Basic $(echo -n "${ES_USERNAME}:${ES_PASSWORD}" | base64)"
fi

# ── Check real Claro OTel logs are flowing ────────────────────────────────────
LOG_COUNT=$(curl -sk "${ES_URL}/logs.otel/_count" \
  -H "$AUTH_HEADER" 2>/dev/null \
  | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null || echo "0")

[[ "$LOG_COUNT" -ge 100 ]] || fail "Expected ≥100 OTel log documents in logs.otel, got ${LOG_COUNT}. Generators may still be starting — wait 1-2 minutes and try again."
pass "Claro OTel logs flowing: ${LOG_COUNT} documents in logs.otel"

# ── Check ERROR logs with trace.id (core of architectural unity demo) ─────────
CORR_COUNT=$(curl -sk "${ES_URL}/logs.otel/_count" \
  -H "$AUTH_HEADER" \
  -H "Content-Type: application/json" \
  -d '{"query":{"bool":{"must":[{"term":{"severity_text":"ERROR"}},{"exists":{"field":"trace.id"}}]}}}' \
  2>/dev/null \
  | python3 -c "import sys,json; print(json.load(sys.stdin).get('count',0))" 2>/dev/null || echo "0")

[[ "$CORR_COUNT" -ge 1 ]] || fail "No ERROR logs with trace.id found — correlation data not yet available. Wait 1-2 minutes and try again."
pass "Trace-correlated ERROR logs found: ${CORR_COUNT} logs with trace.id"

echo ""
echo "🎉 Lab 4 complete! Elastic's single datastore enables instant trace-to-log correlation."
echo "   In Splunk, this requires switching between two products and two query languages."
exit 0
