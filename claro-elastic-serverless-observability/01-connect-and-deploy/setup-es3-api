#!/usr/bin/env bash
# Challenge 1 setup: verify the app is healthy and deployment is active.
set -euo pipefail

log()  { printf "[ch1-setup] %s\n" "$*"; }

APP="http://localhost:8090"
DEMO_PORT=8090

# ── Wait for app health ───────────────────────────────────────────────────────
for i in $(seq 1 30); do
  if curl -sf "${APP}/health" >/dev/null 2>&1; then
    log "App healthy ✓"
    break
  fi
  sleep 2
  if [[ $i -eq 30 ]]; then
    log "App not healthy after 60s — attempting restart..."
    systemctl restart elastic-demo
    sleep 5
    if curl -sf "${APP}/health" >/dev/null 2>&1; then
      log "App healthy after restart ✓"
    else
      log "ERROR: App still not healthy. Check: journalctl -u elastic-demo"
      exit 1
    fi
  fi
done

# ── Ensure the claro deployment is registered ─────────────────────────────────
# After a service restart the in-memory registry is rebuilt from SQLite.
# If the track-level deployer hadn't saved to SQLite yet before the restart,
# the deployment is lost. Re-launch to restore it.
RUNNING="$(curl -sf "${APP}/api/deployments" 2>/dev/null \
  | python3 -c "import sys,json; deps=json.load(sys.stdin); print(sum(1 for d in deps if d.get('running')))" \
  2>/dev/null || echo 0)"

if [[ "${RUNNING:-0}" -lt 1 ]]; then
  log "No active deployment found — re-launching claro scenario..."

  # Pull credentials from agent variables (set by track setup)
  KIBANA_URL="$(agent variable get ES_KIBANA_URL 2>/dev/null || echo "")"
  API_KEY="$(agent variable get ES_API_KEY 2>/dev/null || echo "")"

  if [[ -n "$KIBANA_URL" && -n "$API_KEY" ]]; then
    curl -sf -X POST "${APP}/api/setup/launch" \
      -H 'Content-Type: application/json' \
      -d "{\"scenario_id\":\"claro\",\"kibana_url\":\"${KIBANA_URL}\",\"api_key\":\"${API_KEY}\"}" \
      >/dev/null 2>&1 || log "WARN: Re-launch request failed"

    log "Waiting for deployment to register (up to 3 min)..."
    for i in $(seq 1 90); do
      RUNNING="$(curl -sf "${APP}/api/deployments" 2>/dev/null \
        | python3 -c "import sys,json; deps=json.load(sys.stdin); print(sum(1 for d in deps if d.get('running')))" \
        2>/dev/null || echo 0)"
      if [[ "${RUNNING:-0}" -ge 1 ]]; then
        log "Deployment active after $((i*2))s ✓"
        break
      fi
      sleep 2
    done
  else
    log "WARN: Could not retrieve Kibana URL/API key — learner may need to re-launch manually."
  fi
else
  log "Deployment active (${RUNNING} running) ✓"
fi
