#!/usr/bin/env bash
# Challenge 6 setup: Searchable Snapshots (Frozen Tier demo)
# Ingest synthetic audit logs timestamped 2 years ago alongside recent logs.
# Uses only curl + python3 json/datetime (no requests library needed).
set -euo pipefail

log()  { printf "[ch6-setup] %s\n" "$*"; }
fail() { printf "[ch6-setup] ERROR: %s\n" "$*" >&2; exit 1; }

ES_URL=$(agent variable get ES_URL 2>/dev/null || echo "")
ES_API_KEY=$(agent variable get ES_API_KEY 2>/dev/null || echo "")
ES_USERNAME=$(agent variable get ES_USERNAME 2>/dev/null || echo "admin")
ES_PASSWORD=$(agent variable get ES_PASSWORD 2>/dev/null || echo "")

[[ -z "$ES_URL" ]] && fail "ES_URL not set."
if [[ -n "$ES_API_KEY" ]]; then
  AUTH_HEADER="Authorization: ApiKey ${ES_API_KEY}"
else
  AUTH_HEADER="Authorization: Basic $(echo -n "${ES_USERNAME}:${ES_PASSWORD}" | base64)"
fi

es() {
  local method="$1" path="$2" body="${3:-}"
  if [[ -n "$body" ]]; then
    curl -sk -X "$method" "${ES_URL}${path}" \
      -H "$AUTH_HEADER" -H "Content-Type: application/json" -d "$body"
  else
    curl -sk -X "$method" "${ES_URL}${path}" -H "$AUTH_HEADER"
  fi
}

# ── Index template ─────────────────────────────────────────────────────────────
log "Creating audit log index template..."
es PUT "/_index_template/lab6-audit-logs" '{
  "index_patterns": ["lab6-audit-logs-*"],
  "template": {
    "settings": {"number_of_shards": 1, "number_of_replicas": 0},
    "mappings": {
      "properties": {
        "@timestamp":                {"type":"date"},
        "event.action":              {"type":"keyword"},
        "event.category":            {"type":"keyword"},
        "event.outcome":             {"type":"keyword"},
        "user.name":                 {"type":"keyword"},
        "user.id":                   {"type":"keyword"},
        "user.roles":                {"type":"keyword"},
        "source.ip":                 {"type":"ip"},
        "destination.service":       {"type":"keyword"},
        "http.response.status_code": {"type":"integer"},
        "resource.type":             {"type":"keyword"},
        "resource.id":               {"type":"keyword"},
        "message":                   {"type":"text"},
        "tier":                      {"type":"keyword"},
        "compliance.framework":      {"type":"keyword"}
      }
    }
  }
}' | python3 -c "import sys,json; r=json.load(sys.stdin); print('  template:', r.get('acknowledged','?'))"

# ── Generate bulk NDJSON and index via curl ────────────────────────────────────
log "Generating archival + recent audit logs..."

python3 - <<'PYEOF'
import json, random, sys
from datetime import datetime, timedelta, timezone

NOW       = datetime.now(timezone.utc)
BASE_DATE = NOW - timedelta(days=730)

ARCH_DATE = BASE_DATE.strftime('%Y.%m.%d')
HOT_DATE  = NOW.strftime('%Y.%m.%d')

print(f"{ARCH_DATE}", file=sys.stderr)
print(f"{HOT_DATE}", file=sys.stderr)

USERS     = [f"user_{i:03d}" for i in range(1, 41)]
SERVICES  = ["payments-api", "user-mgmt", "reporting", "data-export", "admin-portal"]
ACTIONS   = ["login", "logout", "data_access", "configuration_change", "data_export",
             "privilege_escalation_attempt", "bulk_delete", "schema_change", "api_key_created"]
FRAMEWORKS= ["SOC2", "PCI-DSS", "HIPAA", "ISO-27001"]
ROLES     = ["readonly", "analyst", "admin", "superuser"]

def make_doc(ts, tier):
    action  = random.choice(ACTIONS)
    user    = random.choice(USERS)
    svc     = random.choice(SERVICES)
    outcome = "failure" if action == "privilege_escalation_attempt" else random.choice(["success","success","failure"])
    return {
        "@timestamp":                ts.strftime("%Y-%m-%dT%H:%M:%S.000Z"),
        "event.action":              action,
        "event.category":            "authentication" if "login" in action else "database",
        "event.outcome":             outcome,
        "user.name":                 user,
        "user.id":                   f"uid-{abs(hash(user)) % 100000:05d}",
        "user.roles":                random.choice(ROLES),
        "source.ip":                 f"10.{random.randint(0,255)}.{random.randint(0,255)}.{random.randint(1,254)}",
        "destination.service":       svc,
        "http.response.status_code": 200 if outcome == "success" else random.choice([401, 403, 500]),
        "resource.type":             random.choice(["customer_record","payment_data","config","api_key"]),
        "resource.id":               f"res-{random.randint(10000,99999)}",
        "message":                   f"User {user} performed {action} on {svc} — outcome: {outcome}",
        "tier":                      tier,
        "compliance.framework":      random.choice(FRAMEWORKS)
    }

lines = []

# 500 archival docs (2 years ago)
arch_index = f"lab6-audit-logs-{ARCH_DATE}"
for i in range(500):
    ts = BASE_DATE + timedelta(days=random.randint(0,6), hours=random.randint(0,23), minutes=random.randint(0,59))
    lines.append(json.dumps({"index": {"_index": arch_index}}))
    lines.append(json.dumps(make_doc(ts, "frozen")))

# 100 recent docs (last 48h)
hot_index = f"lab6-audit-logs-{HOT_DATE}"
for i in range(100):
    ts = NOW - timedelta(hours=random.randint(0, 48))
    lines.append(json.dumps({"index": {"_index": hot_index}}))
    lines.append(json.dumps(make_doc(ts, "hot")))

print("\n".join(lines))
PYEOF

# Capture index names from stderr and bulk NDJSON from stdout
log "Bulk indexing via curl..."
BULK_NDJSON=$(python3 - 2>/tmp/lab6_dates.txt <<'PYEOF'
import json, random, sys
